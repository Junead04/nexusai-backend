# =====================================================
#  NexusAI Backend .env  — COPY TO .env AND FILL IN
#  cp .env.example .env   (then edit .env)
# =====================================================

# ── STEP 1: GROQ API KEY (REQUIRED) ──────────────────
# Get FREE at: https://console.groq.com
# Sign up → API Keys → Create API Key → copy the key (starts with gsk_)
GROQ_API_KEY_70B=gsk_REPLACE_WITH_YOUR_ACTUAL_GROQ_KEY
GROQ_API_KEY_8B=gsk_REPLACE_WITH_YOUR_ACTUAL_GROQ_KEY

# ── STEP 2: Security ─────────────────────────────────
SECRET_KEY=nexusai-super-secret-key-change-me-2024

# ── STEP 3: URLs (keep as-is for local dev) ──────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

ENVIRONMENT=development

# ── OPTIONAL: LangSmith monitoring ───────────────────
# Leave blank to disable (avoids 403 errors)
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nexusai-dev

# ── OPTIONAL: Google OAuth ────────────────────────────
# Follow setup guide to get these from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
